<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="25dp"
    android:paddingTop="4dp"
    android:paddingEnd="25dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/tvPriceListBlockedMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:text="@string/cannot_deleting_pricelist_message"
        android:textAppearance="?attr/textAppearanceBody1" />

    <TableLayout
        android:id="@+id/tlPriceListBlockedUsage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:shrinkColumns="1"
        android:stretchColumns="0,1">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/pricelist_usage_uninvoiced"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPriceListBlockedTedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minEms="3"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="0dp"
                android:paddingBottom="6dp"
                android:textStyle="bold" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/pricelist_usage_invoices"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPriceListBlockedFakCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minEms="3"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="0dp"
                android:paddingBottom="6dp"
                android:textStyle="bold" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/pricelist_usage_monthly_readings"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPriceListBlockedMonCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minEms="3"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="0dp"
                android:paddingBottom="6dp"
                android:textStyle="bold" />
        </TableRow>
    </TableLayout>

</LinearLayout>


