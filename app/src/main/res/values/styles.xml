<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MyNavigationViewStyle" parent="Widget.MaterialComponents.NavigationView">
        <item name="itemTextColor">@color/nav_menu_item_color</item>
        <item name="itemIconTint">@color/nav_menu_item_color</item>
        <item name="itemBackground">@color/nav_menu_background</item>
        <item name="background">@color/color_hdo_time_TUV</item>
        <item name="itemTextAppearance">@style/NavMenuItemTextAppearance</item>
    </style>

    <!-- Define a new style for NavigationView -->
    <style name="DialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_rounded_background</item>
        <item name="android:background">@drawable/dialog_rounded_background</item>
        <item name="android:textColor">@color/dialog_text_primary</item>
        <item name="android:textColorPrimary">@color/dialog_text_primary</item>
        <item name="android:textColorSecondary">@color/dialog_text_primary</item>
        <item name="android:buttonBarButtonStyle">@style/DialogButtonStyle</item>
        <item name="colorAccent">@color/dialog_button_text</item>
        <item name="android:colorAccent">@color/dialog_button_text</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:dividerHeight">0dp</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/dialog_button_text</item>
    </style>

    <!-- Define text appearance for navigation menu items -->
    <style name="NavMenuItemTextAppearance" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/nav_menu_item_color</item>
    </style>

    <!-- Define color RippleItem-->
    <style name="NavigationItemNoRipple">
        <item name="android:colorControlHighlight">@android:color/transparent</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>

    <style name="StyleTvAlert">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/shape_item</item>
        <item name="android:padding">10dp</item>
        <item name="android:text">@string/create_place</item>
        <item name="android:textAppearance">@style/TextAppearance.AppCompat.Large</item>
    </style>
</resources>